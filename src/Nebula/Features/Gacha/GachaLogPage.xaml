<?xml version="1.0" encoding="utf-8" ?>
<sf:PageBase x:Class="Nebula.Features.Gacha.GachaLogPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lang="using:Nebula.Language"
             xmlns:local="using:Nebula.Features.Gacha"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sc="using:Nebula.Controls"
             xmlns:sf="using:Nebula.Frameworks"
             x:DefaultBindMode="OneWay"
             mc:Ignorable="d">

    <Page.Resources>
        <local:RarityToGIBgConverter x:Key="RarityToGIBgConverter" />
        <local:RarityToSRBgConverter x:Key="RarityToSRBgConverter" />
        <local:RarityToZZZIconConverter x:Key="RarityToZZZIconConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition />
        </Grid.RowDefinitions>


        <TextBlock Margin="24,0,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   FontSize="20"
                   FontWeight="Bold"
                   Text="{x:Bind GachaTypeText}" />


        <StackPanel HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="16">
            <!--  Uid List  -->
            <ComboBox Name="ComboBox_Uid"
                      MinWidth="140"
                      VerticalAlignment="Center"
                      ItemsSource="{x:Bind UidList}"
                      SelectedItem="{x:Bind SelectUid, Mode=TwoWay}" />
            <Button x:Name="Button_EndfieldLogin"
                    Height="32"
                    Command="{x:Bind LoginEndfieldAccountCommand}"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Margin="0,2,0,0"
                              FontSize="14"
                              Glyph="&#xE77B;" />
                    <TextBlock Text="&#x8D26;&#x53F7;&#x767B;&#x5F55;" />
                </StackPanel>
            </Button>
            <!--  Update  -->
            <SplitButton Height="32" Command="{x:Bind UpdateGachaLogCommand}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Margin="0,2,0,0"
                              FontSize="14"
                              Glyph="&#xE72C;" />
                    <!--  更新记录  -->
                    <TextBlock Text="{x:Bind lang:Lang.GachaLogPage_UpdateRecords}" />
                </StackPanel>
                <SplitButton.Flyout>
                    <MenuFlyout>
                        <!--  更新 保存�?URL  -->
                        <MenuFlyoutItem x:Name="MenuFlyoutItem_UpdateSavedUrl"
                                        Command="{x:Bind UpdateGachaLogCommand}"
                                        CommandParameter="cache"
                                        Text="{x:Bind lang:Lang.GachaLogPage_UpdateSavedURL}" />
                        <!--  更新 全部  -->
                        <MenuFlyoutItem Command="{x:Bind UpdateGachaLogCommand}"
                                        CommandParameter="all"
                                        Text="{x:Bind lang:Lang.GachaLogPage_UpdateAll}" />
                        <!--  �?米游�?同步  -->
                        <MenuFlyoutItem x:Name="MenuFlyoutItem_SyncFromMiyoushe"
                                        Command="{x:Bind SyncFromMiyousheCommand}"
                                        Text="{x:Bind lang:Lang.GachaLogPage_SyncFromMiyoushe}"
                                        Visibility="Collapsed" />
                        <MenuFlyoutItem x:Name="MenuFlyoutItem_SyncFromMiyousheAll"
                                        Command="{x:Bind SyncFromMiyousheCommand}"
                                        CommandParameter="all"
                                        Text="{x:Bind lang:Lang.GachaLogPage_SyncFromMiyousheAll}"
                                        Visibility="Collapsed" />
                        <!--  �?HoYoLAB 同步  -->
                        <MenuFlyoutItem x:Name="MenuFlyoutItem_SyncFromHoYoLAB"
                                        Command="{x:Bind SyncFromMiyousheCommand}"
                                        Text="{x:Bind lang:Lang.GachaLogPage_SyncFromHoYoLAB}"
                                        Visibility="Collapsed" />
                        <MenuFlyoutItem x:Name="MenuFlyoutItem_SyncFromHoYoLABAll"
                                        Command="{x:Bind SyncFromMiyousheCommand}"
                                        CommandParameter="all"
                                        Text="{x:Bind lang:Lang.GachaLogPage_SyncAllFromHoYoLAB}"
                                        Visibility="Collapsed" />
                        <!--  输入 URL  -->
                        <MenuFlyoutItem x:Name="MenuFlyoutItem_InputUrl" Command="{x:Bind InputUrlCommand}" Text="{x:Bind lang:Lang.GachaLogPage_InputURL}" />
                        <MenuFlyoutItem x:Name="MenuFlyoutItem_CloudGame"
                                        Command="{x:Bind OpenCloudGameWindowCommand}"
                                        Text="{x:Bind lang:Lang.GachaLogPage_ViaCloudGame}" />
                    </MenuFlyout>
                </SplitButton.Flyout>
            </SplitButton>
            <!--  Setting  -->
            <Button>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Margin="0,2,0,0"
                              FontSize="14"
                              Glyph="&#xE713;" />
                    <!--  设置  -->
                    <TextBlock Text="{x:Bind lang:Lang.Common_Setting}" />
                </StackPanel>
                <Button.Flyout>
                    <Flyout>
                        <StackPanel MinWidth="200" Spacing="8">
                            <!--  其他设置  -->
                            <TextBlock FontSize="16" Text="{x:Bind lang:Lang.GachaLogPage_OtherSettings}" />

                            <!--  复制 URL  -->
                            <Button Margin="0,8,0,0" Command="{x:Bind CopyUrlCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Name="FontIcon_CopyUrl"
                                              FontSize="16"
                                              Glyph="&#xE8C8;" />
                                    <TextBlock Text="{x:Bind lang:Lang.GachaLogPage_CopyURL}" />
                                </StackPanel>
                            </Button>

                            <!--  总是出现 Authkey Timeout  -->
                            <TextBlock x:Name="TextBlock_AuthkeyTimeout"
                                       Margin="0,8,0,0"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="{x:Bind lang:Lang.GachaLogPage_AuthkeyTimeoutAlwaysOccurs}" />
                            <TextBlock x:Name="TextBlock_DeleteCacheHint"
                                       Margin="0,-4,0,0"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="{x:Bind lang:Lang.GachaLogPage_RestartGameAfterDeletingTheCacheFolder}"
                                       TextWrapping="Wrap" />
                            <Button x:Name="MenuFlyoutItem_DeleteCacheFolder" Command="{x:Bind DeleteGachaCacheFolderCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="16" Glyph="&#xEA99;" />
                                    <!--  删除缓存文件�? -->
                                    <TextBlock Text="{x:Bind lang:Lang.GachaLogPage_DeleteCacheFolder}" />
                                </StackPanel>
                            </Button>

                            <!--  语言  -->
                            <StackPanel x:Name="StackPanel_GachaLanguage"
                                        Margin="0,4,0,0"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind lang:Lang.GachaLogPage_Language}" />
                                <Button Padding="1"
                                        VerticalAlignment="Bottom"
                                        Style="{ThemeResource DateTimePickerFlyoutButtonStyle}">
                                    <FontIcon FontSize="12" Glyph="&#xE9CE;" />
                                    <Button.Flyout>
                                        <Flyout>
                                            <TextBlock Text="{x:Bind lang:Lang.GachaLogPage_GachaLanguageDesc}" />
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                            </StackPanel>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox MinWidth="100" Text="{x:Bind GachaLanguage, Mode=TwoWay}" />
                                <Button Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        Command="{x:Bind ChangeGachaItemNameCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Margin="0,2,0,0"
                                                  FontSize="16"
                                                  Glyph="&#xE8FB;" />
                                        <TextBlock Text="{x:Bind lang:Lang.Common_Apply}" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!--  分割�? -->
                            <MenuFlyoutSeparator />

                            <!--  导入导出  -->
                            <Button HorizontalAlignment="Stretch" Content="{x:Bind lang:Lang.GachaLogPage_ImportAndExport}">
                                <Button.Flyout>
                                    <Flyout>
                                        <StackPanel MinWidth="200" Spacing="8">
                                            <!--  导出�? -->
                                            <StackPanel Margin="0,8,0,0"
                                                        Orientation="Horizontal"
                                                        Spacing="8">
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind lang:Lang.GachaLogPage_ExportAs}" />
                                                <Button Padding="1"
                                                        VerticalAlignment="Bottom"
                                                        Style="{ThemeResource DateTimePickerFlyoutButtonStyle}">
                                                    <FontIcon FontSize="12" Glyph="&#xE9CE;" />
                                                    <Button.Flyout>
                                                        <Flyout>
                                                            <TextBlock>
                                                                <Hyperlink NavigateUri="https://uigf.org/" UnderlineStyle="None">
                                                                    <Run Text="UIGF/SRGF" />
                                                                </Hyperlink>
                                                            </TextBlock>
                                                        </Flyout>
                                                    </Button.Flyout>
                                                </Button>
                                            </StackPanel>
                                            <!--  Excel Json  -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition />
                                                    <ColumnDefinition />
                                                </Grid.ColumnDefinitions>
                                                <Button x:Name="Button_Export_Excel"
                                                        HorizontalAlignment="Stretch"
                                                        Command="{x:Bind ExportGachaLogCommand}"
                                                        CommandParameter="excel"
                                                        Content="Excel"
                                                        CornerRadius="4,0,0,4" />
                                                <Button x:Name="Button_Export_JSON"
                                                        Grid.Column="1"
                                                        HorizontalAlignment="Stretch"
                                                        Command="{x:Bind ExportGachaLogCommand}"
                                                        CommandParameter="json"
                                                        Content="Json"
                                                        CornerRadius="0,4,4,0" />
                                            </Grid>
                                            <!--  �?Json 导入  -->
                                            <Button x:Name="Button_Import"
                                                    HorizontalAlignment="Stretch"
                                                    Command="{x:Bind ImportGachaLogCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon Margin="0,2,0,0"
                                                              FontSize="16"
                                                              Glyph="&#xEA52;" />
                                                    <TextBlock Text="{x:Bind lang:Lang.GachaLogPage_ImportFromJson}" />
                                                </StackPanel>
                                            </Button>
                                            <!--  UIGF v4.0  -->
                                            <Button x:Name="Button_UIGF4"
                                                    HorizontalAlignment="Stretch"
                                                    Command="{x:Bind OpenUIGF4WindowCommand}"
                                                    Content="UIGF v4.0" />
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>

                            <!--  隐藏卡池  -->
                            <Button HorizontalAlignment="Stretch" Content="{x:Bind lang:Lang.GachaLogPage_HideGachaBanners}">
                                <Button.Flyout>
                                    <Flyout>
                                        <ListView x:Name="ListView_GachaBanners"
                                                  MinWidth="200"
                                                  ItemsSource="{x:Bind GachaBanners}"
                                                  SelectionMode="Multiple">
                                            <ListView.ItemTemplate>
                                                <DataTemplate x:DataType="local:GachaBanner">
                                                    <TextBlock Text="{x:Bind ToLocalization()}" />
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>

                            <!--  删除记录  -->
                            <Button HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="14"
                                              Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                              Glyph="&#xE74D;" />
                                    <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}" Text="{x:Bind lang:Lang.GachaLogPage_DeleteRecords}" />
                                </StackPanel>
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Command="{x:Bind DeleteUidCommand}"
                                                        FontSize="14"
                                                        Text="{x:Bind lang:Lang.GachaLogPage_DeleteAll}" />
                                        <MenuFlyoutItem Command="{x:Bind DeleteUidByTimeCommand}"
                                                        FontSize="14"
                                                        Text="{x:Bind lang:Lang.GachaLogPage_SpecificTimePeriod}" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
            <!--  Pane  -->
            <Button Height="32"
                    BorderThickness="0"
                    Command="{x:Bind OpenItemStatsPaneCommand}"
                    CornerRadius="14,0,0,14"
                    IsEnabled="{x:Bind GachaItemStats, Converter={StaticResource ObjectToBoolConverter}}"
                    Style="{ThemeResource AccentButtonStyle}">
                <FontIcon Margin="6,2,4,0"
                          FontSize="18"
                          Glyph="&#xE8A0;" />
            </Button>
        </StackPanel>

        <StackPanel Name="StackPanel_Emoji"
                    Grid.RowSpan="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16"
                    Visibility="Collapsed">
            <Image Name="Image_Emoji"
                   Width="160"
                   Height="160" />
            <TextBlock HorizontalAlignment="Center"
                       FontSize="16"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind lang:Lang.GachaLogPage_NoGachaRecords}" />
        </StackPanel>


        <SplitView Name="SplitView_Content"
                   Grid.Row="1"
                   BorderThickness="0"
                   CornerRadius="12,0,0,12"
                   DisplayMode="Overlay"
                   OpenPaneLength="508"
                   PaneBackground="{ThemeResource CustomOverlayAcrylicBrush}"
                   PanePlacement="Right">


            <ScrollViewer x:Name="ScrollViewer_GachaStats"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollMode="Auto">
                <Grid x:Name="Grid_GachaStats"
                      Margin="20,0,20,16"
                      Background="Transparent">
                    <ItemsControl x:Name="ItemsControl_GachaStats"
                                  x:Load="{x:Bind IsDefaultGachaStatsCardVisible}"
                                  ItemsSource="{x:Bind DisplayGachaTypeStatsCollection}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="12" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:GachaTypeStats">
                                <local:GachaStatsCard Loaded="GachaStatsCard_Loaded"
                                                      Unloaded="GachaStatsCard_Unloaded"
                                                      WarpTypeStats="{x:Bind}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl x:Name="ItemsControl_ZZZGachaStats"
                                  x:Load="{x:Bind IsZZZGachaStatsCardVisible}"
                                  ItemsSource="{x:Bind DisplayGachaTypeStatsCollection}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="12" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:GachaTypeStats">
                                <local:ZZZGachaStatsCard Loaded="GachaStatsCard_Loaded"
                                                         Unloaded="GachaStatsCard_Unloaded"
                                                         WarpTypeStats="{x:Bind}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>


            <SplitView.Pane>
                <Grid>
                    <GridView Name="GridView_GachaItemStats_Genshin"
                              Padding="24,12,24,12"
                              x:Load="{x:Bind EnableGenshinGachaItemStats}"
                              ItemsSource="{x:Bind GachaItemStats}"
                              SelectionMode="None">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="local:GachaLogItemEx">
                                <Grid Width="80"
                                      Height="97"
                                      Margin="4,2,4,2">
                                    <sc:CachedImage Source="{x:Bind RankType, Converter={StaticResource RarityToGIBgConverter}}" />
                                    <sc:CachedImage Height="80"
                                                    VerticalAlignment="Top"
                                                    CornerRadius="0,0,16,0"
                                                    Source="{x:Bind Icon}" />
                                    <TextBlock Margin="0,0,0,1"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Bottom"
                                               FontSize="12"
                                               Foreground="#84603D">
                                        <Run Text="{x:Bind ItemCount}" />
                                        <Run Text="{x:Bind lang:Lang.SpiralAbyssPage_Times}" />
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                    <GridView Name="GridView_GachaItemStats_StarRail"
                              Padding="24,12,24,12"
                              HorizontalAlignment="Center"
                              x:Load="{x:Bind EnableStarRailGachaItemStats}"
                              ItemsSource="{x:Bind GachaItemStats}"
                              SelectionMode="None">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="local:GachaLogItemEx">
                                <Grid Width="80"
                                      Height="93"
                                      Margin="4,2,4,2">
                                    <sc:CachedImage Source="{x:Bind RankType, Converter={StaticResource RarityToSRBgConverter}}" />
                                    <sc:CachedImage Width="80"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Top"
                                                    CornerRadius="0,12,0,0"
                                                    Source="{x:Bind Icon}"
                                                    Stretch="Uniform" />
                                    <Border Height="16"
                                            Margin="0,0,0,2"
                                            VerticalAlignment="Bottom"
                                            Background="#A0000000">
                                        <TextBlock Margin="0,0,0,1"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="12">
                                            <Run Text="{x:Bind ItemCount}" />
                                            <Run Text="{x:Bind lang:Lang.SpiralAbyssPage_Times}" />
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                    <GridView Name="GridView_GachaItemStats_ZZZ"
                              Padding="24,12,24,12"
                              x:Load="{x:Bind EnableZZZGachaItemStats}"
                              ItemsSource="{x:Bind GachaItemStats}"
                              SelectionMode="None">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="local:GachaLogItemEx">
                                <Grid Width="80"
                                      Height="98"
                                      Margin="4,2,4,2"
                                      Background="Black"
                                      CornerRadius="8">
                                    <sc:CachedImage Width="80"
                                                    Height="80"
                                                    VerticalAlignment="Top"
                                                    Source="ms-appx:///Assets/Image/ZZZ_AvatarCard_Background.png" />
                                    <sc:CachedImage Width="80"
                                                    Height="80"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Top"
                                                    Source="{x:Bind Icon}"
                                                    Stretch="UniformToFill" />
                                    <Border HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Background="#0A0A0A"
                                            CornerRadius="0,0,4,0">
                                        <sc:CachedImage Width="20"
                                                        Height="20"
                                                        Margin="2"
                                                        Source="{x:Bind RankType, Converter={StaticResource RarityToZZZIconConverter}}" />
                                    </Border>
                                    <TextBlock Margin="0,0,0,1"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Bottom"
                                               FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                        <Run Text="{x:Bind ItemCount}" />
                                        <Run Text="{x:Bind lang:Lang.SpiralAbyssPage_Times}" />
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                    <GridView Name="GridView_GachaItemStats_Generic"
                              Padding="24,12,24,12"
                              x:Load="{x:Bind EnableGenericGachaItemStats}"
                              ItemsSource="{x:Bind GachaItemStats}"
                              SelectionMode="None">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="local:GachaLogItemEx">
                                <Grid Width="80"
                                      Height="98"
                                      Margin="4"
                                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                      CornerRadius="8">
                                    <sc:CachedImage Width="80"
                                                    Height="80"
                                                    VerticalAlignment="Top"
                                                    Source="{x:Bind Icon}"
                                                    Stretch="UniformToFill"
                                                    Visibility="{x:Bind HasIcon, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <StackPanel Margin="8"
                                                VerticalAlignment="Center"
                                                Spacing="2"
                                                Visibility="{x:Bind HasIcon, Converter={StaticResource BoolToVisibilityReversedConverter}}">
                                        <TextBlock HorizontalAlignment="Center"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   MaxLines="2"
                                                   Text="{x:Bind Name}"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="Wrap" />
                                        <TextBlock HorizontalAlignment="Center"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                            <Run Text="{x:Bind RankType}" /><Run Text=" star" />
                                        </TextBlock>
                                    </StackPanel>
                                    <Border Height="18"
                                            VerticalAlignment="Bottom"
                                            Background="#A0000000">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="12">
                                            <Run Text="{x:Bind ItemCount}" />
                                            <Run Text="{x:Bind lang:Lang.SpiralAbyssPage_Times}" />
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </Grid>
            </SplitView.Pane>


        </SplitView>


    </Grid>

</sf:PageBase>
